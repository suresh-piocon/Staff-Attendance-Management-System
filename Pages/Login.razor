@page "/login"
@layout SalesmanAttendance.Layout.EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Nav
@inject SupabaseAuthStateProvider AuthStateProvider

<div class="login-page">
    <div class="login-bg-glow"></div>
    <div class="login-card">
        <div class="login-logo">🧣</div>
        <h1 class="login-title">Silk Saree Attendance</h1>
        <p class="login-subtitle">Sign in to manage your sales team</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @errorMessage
            </div>
        }

        <div class="form-group">
            <label class="form-label">Email Address</label>
            <input type="email" class="form-control" placeholder="admin@silksaree.com"
                   @bind="email" @bind:event="oninput" @onkeydown="HandleKeyDown" />
        </div>

        <div class="form-group">
            <label class="form-label">Password</label>
            <input type="password" class="form-control" placeholder="••••••••"
                   @bind="password" @bind:event="oninput" @onkeydown="HandleKeyDown" />
        </div>

        <button class="login-btn" @onclick="HandleLogin" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-sm"></span>
                <span>Signing in...</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>

        <p style="text-align:center; margin-top:20px; font-size:12px; color:var(--text-muted);">
            Default Admin: admin@silksaree.com
        </p>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";
    private bool isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticated)
        {
            RedirectByRole();
        }
    }

    private async Task HandleLogin()
    {
        errorMessage = "";
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter both email and password.";
            return;
        }

        isLoading = true;
        try
        {
            var session = await AuthService.SignInAsync(email.Trim(), password);
            if (session != null)
            {
                AuthStateProvider.NotifyAuthStateChanged();
                RedirectByRole();
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message.Contains("Invalid") ? "Invalid email or password." : "Login failed. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void RedirectByRole()
    {
        var role = AuthService.GetUserRole();
        Nav.NavigateTo(role == "Admin" ? "/admin/dashboard" : "/salesman/dashboard");
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }
}
