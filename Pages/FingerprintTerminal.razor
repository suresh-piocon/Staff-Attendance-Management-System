@page "/fingerprint-terminal"
@inject StaffService StaffService
@inject AttendanceService AttendanceService

<PageTitle>Fingerprint Terminal — Silk Saree</PageTitle>

<div class="page-header" style="justify-content:center;">
    <h1 style="text-align:center;"><i class="bi bi-fingerprint"></i> Fingerprint Attendance Terminal</h1>
</div>

<div class="d-flex" style="justify-content:center; align-items:center; min-height:60vh; padding: 20px;">
    <div class="glass-card" style="width:100%; max-width:500px; padding: 30px; text-align: center; position: relative; overflow: hidden;">
        <div class="login-bg-glow" style="top: -50px; left: -50px; width: 150px; height: 150px;"></div>
        
        <div style="font-size: 13px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 24px;">
            Device Kiosk Simulation
        </div>

        @if (!string.IsNullOrEmpty(statusMessage))
        {
            <div style="background:rgba(46,204,113,0.15); border:1px solid rgba(46,204,113,0.4); border-radius:10px; padding:14px 20px; margin-bottom:20px; color:#2ecc71; text-align: left; display:flex; align-items:center; gap:10px;">
                <i class="bi bi-check-circle-fill" style="font-size: 18px;"></i>
                <div>
                    <strong>Punch Recorded!</strong><br />
                    <span style="font-size: 13px; color: var(--text-secondary);">@statusMessage</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="background:rgba(231,76,60,0.15); border:1px solid rgba(231,76,60,0.4); border-radius:10px; padding:14px 20px; margin-bottom:20px; color:#e74c3c; text-align: left; display:flex; align-items:center; gap:10px;">
                <i class="bi bi-exclamation-triangle-fill" style="font-size: 18px;"></i>
                <div>
                    <strong>Punch Failed</strong><br />
                    <span style="font-size: 13px; color: var(--text-secondary);">@errorMessage</span>
                </div>
            </div>
        }

        <!-- Scanner Selector -->
        <div class="form-group" style="text-align: left; margin-bottom: 20px;">
            <label class="form-label">Select Staff Member (Fingerprint ID)</label>
            <select class="form-control" @bind="selectedFingerprintId">
                <option value="">-- Touch sensor / Select ID --</option>
                @foreach (var s in activeStaff)
                {
                    <option value="@s.FingerprintEmpId">@s.Name (Fingerprint: @s.FingerprintEmpId)</option>
                }
            </select>
        </div>

        <!-- Simulated Time (Optional for testing) -->
        <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.05); border-radius: 10px; padding: 12px; margin-bottom: 30px; text-align: left;">
            <div class="d-flex" style="justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <span style="font-size: 11px; color: var(--text-gold); font-weight: 600;">Time Offset Simulator</span>
                <input type="checkbox" id="enableOffset" @bind="useCustomTime" style="width: 14px; height: 14px;" />
            </div>
            @if (useCustomTime)
            {
                <div class="d-flex gap-8">
                    <input type="date" class="form-control form-control-sm" @bind="customDate" />
                    <input type="time" class="form-control form-control-sm" @bind="customTime" />
                </div>
            }
            else
            {
                <div style="font-size: 12px; color: var(--text-muted);">
                    Punching at actual time: <strong style="color: var(--text-secondary);">@DateTime.Now.ToString("hh:mm tt")</strong>
                </div>
            }
        </div>

        <!-- Circular Fingerprint Button Scanner -->
        <div style="display:flex; justify-content:center; margin-bottom:30px;">
            <button class="fingerprint-scan-btn @(isScanning ? "scanning" : "")" @onclick="HandleScan" disabled="@(isScanning || string.IsNullOrEmpty(selectedFingerprintId))">
                <div class="fingerprint-icon">
                    <i class="bi bi-fingerprint"></i>
                </div>
                @if (isScanning)
                {
                    <div class="scan-laser"></div>
                }
            </button>
        </div>

        <div style="font-size: 12px; color: var(--text-muted);">
            @if (isScanning)
            {
                <span class="text-info blink">Reading fingerprint sensor...</span>
            }
            else if (string.IsNullOrEmpty(selectedFingerprintId))
            {
                <span>Select a Fingerprint ID to simulate a touch</span>
            }
            else
            {
                <span style="color: var(--text-secondary);">Press scanner button to punch attendance</span>
            }
        </div>
    </div>
</div>

<style>
    /* Premium Scanner Styles */
    .fingerprint-scan-btn {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(20,24,35,0.8) 0%, rgba(10,12,18,0.9) 100%);
        border: 2px solid rgba(201, 162, 39, 0.3);
        box-shadow: 0 0 20px rgba(0,0,0,0.5), inset 0 0 15px rgba(201, 162, 39, 0.1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .fingerprint-scan-btn:hover:not(:disabled) {
        border-color: var(--gold);
        box-shadow: 0 0 25px rgba(201, 162, 39, 0.4), inset 0 0 20px rgba(201, 162, 39, 0.2);
        transform: scale(1.05);
    }

    .fingerprint-scan-btn:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }

    .fingerprint-icon {
        font-size: 64px;
        color: rgba(201, 162, 39, 0.6);
        transition: all 0.3s ease;
    }

    .fingerprint-scan-btn:hover:not(:disabled) .fingerprint-icon {
        color: var(--gold);
        text-shadow: 0 0 10px rgba(201, 162, 39, 0.5);
    }

    /* Scanning laser animation */
    .fingerprint-scan-btn.scanning {
        border-color: #3498db;
        box-shadow: 0 0 30px rgba(52, 152, 219, 0.6), inset 0 0 25px rgba(52, 152, 219, 0.3);
    }

    .fingerprint-scan-btn.scanning .fingerprint-icon {
        color: #3498db;
    }

    .scan-laser {
        position: absolute;
        width: 100%;
        height: 3px;
        background: #3498db;
        box-shadow: 0 0 10px #3498db, 0 0 20px #3498db;
        left: 0;
        top: 0;
        animation: scan 1.8s ease-in-out infinite;
    }

    @@keyframes scan {
        0% { top: 0%; }
        50% { top: 100%; }
        100% { top: 0%; }
    }

    .blink {
        animation: blinker 1.5s linear infinite;
    }

    @@keyframes blinker {
        50% { opacity: 0; }
    }
</style>

@code {
    private List<Staff> activeStaff = new();
    private string selectedFingerprintId = string.Empty;
    private bool isScanning = false;
    private string statusMessage = string.Empty;
    private string errorMessage = string.Empty;

    // Custom time testing
    private bool useCustomTime = false;
    private DateTime customDate = DateTime.Today;
    private DateTime customTime = DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        activeStaff = await StaffService.GetActiveStaffAsync();
    }

    private async Task HandleScan()
    {
        if (string.IsNullOrEmpty(selectedFingerprintId)) return;

        isScanning = true;
        statusMessage = string.Empty;
        errorMessage = string.Empty;
        StateHasChanged();

        // Simulate 1.5 second scanner biometric check
        await Task.Delay(1500);

        try
        {
            DateTime punchTime = DateTime.Now;
            if (useCustomTime)
            {
                punchTime = new DateTime(
                    customDate.Year, customDate.Month, customDate.Day,
                    customTime.Hour, customTime.Minute, 0, DateTimeKind.Local);
            }

            var result = await AttendanceService.RecordFingerprintPunchAsync(selectedFingerprintId, punchTime);
            statusMessage = $"{result.StaffName} — {result.PunchType} logged successfully at {punchTime.ToString("hh:mm tt")}";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isScanning = false;
            StateHasChanged();
        }
    }
}
