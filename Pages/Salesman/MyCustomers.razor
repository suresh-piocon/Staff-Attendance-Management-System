@page "/salesman/customers"
@attribute [Authorize(Roles = "Salesman")]
@inject CustomerService CustomerService
@inject AuthService AuthService
@inject StaffService StaffService
@inject FollowUpService FollowUpService

<PageTitle>My Customers — Silk Saree</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-people"></i> My Customers</h1>
</div>

<div class="filter-bar">
    <input class="form-control" placeholder="Search by name or mobile..." @bind="searchText" @bind:event="oninput" />
    <select class="form-control" @bind="filterStatus">
        <option value="">All Status</option>
        <option>New</option>
        <option>Follow-up Pending</option>
        <option>Interested</option>
        <option>Not Interested</option>
        <option>Converted</option>
        <option>Sale Closed</option>
    </select>
</div>

@if (isLoading)
{
    <div class="loading-container"><span class="spinner-sm"></span> Loading customer data...</div>
}
else
{
    <div class="glass-card">
        <div class="card-body" style="padding:0;">
            <div class="data-table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Customer Name</th>
                            <th>Mobile</th>
                            <th>City</th>
                            <th>Visit Date</th>
                            <th>Remarks</th>
                            <th>Purchase Value</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var filtered = GetFiltered().ToList();
                        }
                        @if (!filtered.Any())
                        {
                            <tr><td colspan="9"><div class="empty-state"><i class="bi bi-person-x"></i><p>No customers assigned to you</p></div></td></tr>
                        }
                        else
                        {
                            @foreach (var (c, idx) in filtered.Select((c, i) => (c, i + 1)))
                            {
                                var statusClass = c.Status.Replace(" ", "").ToLower();
                                <tr>
                                    <td class="muted">@idx</td>
                                    <td class="fw-600">@c.CustomerName</td>
                                    <td class="muted">@c.Mobile</td>
                                    <td class="muted">@c.City</td>
                                    <td class="muted">@c.VisitDate</td>
                                    <td class="muted" style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@c.Remarks">@c.Remarks</td>
                                    <td class="text-success fw-600">₹@(c.PurchaseValue.ToString("N0"))</td>
                                    <td><span class="badge badge-@statusClass">@c.Status</span></td>
                                    <td>
                                        <button class="btn-primary-glass btn-sm" @onclick="() => OpenFollowUp(c)">
                                            <i class="bi bi-bell-plus"></i> Add Follow-Up
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Follow-Up Modal -->
@if (showFollowUpModal && selectedCustomer != null)
{
    <div class="modal-overlay">
        <div class="modal-box">
            <div class="modal-header">
                <h3><i class="bi bi-bell-plus"></i> Add Follow-Up for @selectedCustomer.CustomerName</h3>
                <button class="modal-close" @onclick="() => showFollowUpModal = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Follow-Up Date</label>
                    <input type="date" class="form-control" @bind="followUpDate" />
                </div>
                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select class="form-control" @bind="followUpStatus">
                        <option>Follow-up Pending</option>
                        <option>Interested</option>
                        <option>Not Interested</option>
                        <option>Converted</option>
                        <option>Sale Closed</option>
                    </select>
                </div>
                @if (followUpStatus == "Converted" || followUpStatus == "Sale Closed")
                {
                    <div class="form-group">
                        <label class="form-label">Purchase Value (INR) *</label>
                        <input type="number" class="form-control" placeholder="Enter amount in ₹" @bind="purchaseValueInput" />
                    </div>
                }
                <div class="form-group">
                    <label class="form-label">Remarks</label>
                    <textarea class="form-control" rows="3" placeholder="Add remarks..."
                              @bind="followUpRemarks" style="resize:vertical;"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary-glass" @onclick="() => showFollowUpModal = false">Cancel</button>
                <button class="btn-primary-glass" @onclick="SaveFollowUp" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner-sm"></span> }
                    Save Follow-Up
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Customer> customers = new();
    private string? staffId;
    private string searchText = "";
    private string filterStatus = "";
    private bool isLoading = true;
    
    // Follow-up modal
    private bool showFollowUpModal = false;
    private bool isSaving = false;
    private Customer? selectedCustomer;
    private DateTime followUpDate = DateTime.Today;
    private string followUpStatus = "Follow-up Pending";
    private string followUpRemarks = "";
    private decimal purchaseValueInput = 0;

    protected override async Task OnInitializedAsync()
    {
        var userId = AuthService.GetCurrentUser()?.Id ?? "";
        var staff = await StaffService.GetStaffByUserIdAsync(userId);
        staffId = staff?.Id;
        if (staffId != null)
            customers = await CustomerService.GetCustomersByStaffAsync(staffId);
        isLoading = false;
    }

    private IEnumerable<Customer> GetFiltered()
        => customers
            .Where(c => string.IsNullOrEmpty(searchText) ||
                        c.CustomerName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                        (c.Mobile ?? "").Contains(searchText))
            .Where(c => string.IsNullOrEmpty(filterStatus) || c.Status == filterStatus);

    private void OpenFollowUp(Customer c)
    {
        selectedCustomer = c;
        followUpDate = DateTime.Today;
        followUpStatus = c.Status == "New" ? "Follow-up Pending" : c.Status;
        followUpRemarks = "";
        purchaseValueInput = c.PurchaseValue;
        showFollowUpModal = true;
    }

    private async Task SaveFollowUp()
    {
        if (selectedCustomer == null || staffId == null) return;
        isSaving = true;

        try
        {
            await FollowUpService.AddFollowUpAsync(new FollowUp
            {
                CustomerId = selectedCustomer.Id,
                StaffId = staffId,
                FollowUpDate = followUpDate.ToString("yyyy-MM-dd"),
                Status = followUpStatus,
                Remarks = followUpRemarks
            });

            // Update customer status and purchase value
            if (followUpStatus == "Converted" || followUpStatus == "Sale Closed")
            {
                await CustomerService.UpdateCustomerPurchaseValueAsync(selectedCustomer.Id, purchaseValueInput, followUpStatus);
            }
            else
            {
                await CustomerService.UpdateCustomerStatusAsync(selectedCustomer.Id, followUpStatus);
            }

            showFollowUpModal = false;
            customers = await CustomerService.GetCustomersByStaffAsync(staffId);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error saving follow-up: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }
}
