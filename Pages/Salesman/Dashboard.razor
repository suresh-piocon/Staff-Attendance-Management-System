@page "/salesman/dashboard"
@attribute [Authorize(Roles = "Salesman")]
@inject AttendanceService AttendanceService
@inject CustomerService CustomerService
@inject FollowUpService FollowUpService
@inject AuthService AuthService
@inject StaffService StaffService

<PageTitle>My Dashboard — Silk Saree</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-speedometer2"></i> My Dashboard</h1>
    <div class="page-header-actions">
        <button class="btn-secondary-glass btn-sm" @onclick="LoadData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-container"><span class="spinner-sm"></span> Loading dashboard...</div>
}
else
{
    <!-- Check-In / Check-Out Card -->
    <div class="checkin-card">
        <div style="font-size:13px;color:var(--text-muted);margin-bottom:4px;">Today's Attendance</div>
        <div class="checkin-time" id="live-clock">@currentTime</div>
        <div class="checkin-date">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</div>
        
        <div style="font-size:12px;margin-bottom:16px;color:var(--text-secondary);">
            Status: <span class="badge badge-@GetStatusBadge(todayRecord?.Status ?? "Absent")">@(todayRecord?.Status ?? "Absent")</span>
        </div>

        <!-- Session Punch Times -->
        <div class="d-flex gap-24 mb-16" style="justify-content:center;font-size:12px;color:var(--text-muted);">
            <div>
                <strong>Morning Session:</strong><br />
                In: @(todayRecord?.MorningIn != null ? todayRecord.MorningIn.Value.ToLocalTime().ToString("hh:mm tt") : "--")<br />
                Out: @(todayRecord?.MorningOut != null ? todayRecord.MorningOut.Value.ToLocalTime().ToString("hh:mm tt") : "--")
            </div>
            <div>
                <strong>Evening Session:</strong><br />
                In: @(todayRecord?.AfternoonIn != null ? todayRecord.AfternoonIn.Value.ToLocalTime().ToString("hh:mm tt") : "--")<br />
                Out: @(todayRecord?.EveningOut != null ? todayRecord.EveningOut.Value.ToLocalTime().ToString("hh:mm tt") : "--")
            </div>
        </div>

        <div class="d-flex gap-12" style="justify-content:center;">
            @{
                bool showCheckIn = false;
                bool showCheckOut = false;
                var localHour = DateTime.Now.Hour;

                if (todayRecord == null)
                {
                    showCheckIn = true;
                }
                else
                {
                    if (localHour < 14) // Morning focus
                    {
                        if (todayRecord.MorningIn == null) showCheckIn = true;
                        else if (todayRecord.MorningOut == null) showCheckOut = true;
                        else if (todayRecord.AfternoonIn == null) showCheckIn = true; // allow checking in for afternoon early
                    }
                    else // Afternoon focus
                    {
                        if (todayRecord.AfternoonIn == null) showCheckIn = true;
                        else if (todayRecord.EveningOut == null) showCheckOut = true;
                    }
                }
            }

            @if (showCheckIn)
            {
                <button class="btn-primary-glass" @onclick="CheckIn">
                    <i class="bi bi-box-arrow-in-right"></i> Punch Check-In
                </button>
            }
            @if (showCheckOut)
            {
                <button class="btn-secondary-glass" @onclick="CheckOut">
                    <i class="bi bi-box-arrow-right"></i> Punch Check-Out
                </button>
            }
            @if (!showCheckIn && !showCheckOut)
            {
                <span class="text-success"><i class="bi bi-check-all"></i> Punches completed for today!</span>
            }
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="kpi-grid">
        <div class="kpi-card blue">
            <div class="kpi-icon blue"><i class="bi bi-person-plus"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@todayCustomers.Count</div>
                <div class="kpi-label">Today's Customers</div>
            </div>
        </div>
        <div class="kpi-card gold">
            <div class="kpi-icon gold"><i class="bi bi-people"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@totalCustomers</div>
                <div class="kpi-label">Total Assigned</div>
            </div>
        </div>
        <div class="kpi-card purple">
            <div class="kpi-icon purple"><i class="bi bi-bell"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@pendingFollowUps</div>
                <div class="kpi-label">Pending Follow-Ups</div>
            </div>
        </div>
        <div class="kpi-card rose">
            <div class="kpi-icon rose"><i class="bi bi-calendar-event"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@todayFollowUps.Count</div>
                <div class="kpi-label">Today's Follow-Ups</div>
            </div>
        </div>
    </div>

    <!-- Today's Customers -->
    @if (todayCustomers.Any())
    {
        <div class="glass-card mb-24">
            <div class="card-header">
                <div class="card-title"><i class="bi bi-person-plus"></i> Today's New Customers</div>
            </div>
            <div class="card-body" style="padding:0;">
                <div class="data-table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Mobile</th>
                                <th>City</th>
                                <th>Remarks</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in todayCustomers)
                            {
                                <tr>
                                    <td class="fw-600">@c.CustomerName</td>
                                    <td class="muted">@c.Mobile</td>
                                    <td class="muted">@c.City</td>
                                    <td class="muted">@c.Remarks</td>
                                    <td><span class="badge badge-@c.Status.Replace(" ", "").ToLower()">@c.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Today's Follow-Ups -->
    @if (todayFollowUps.Any())
    {
        <div class="glass-card">
            <div class="card-header">
                <div class="card-title"><i class="bi bi-bell-fill text-warning"></i> Today's Follow-Ups</div>
            </div>
            <div class="card-body" style="padding:0;">
                <div class="data-table-wrapper">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Customer</th>
                                <th>Mobile</th>
                                <th>Status</th>
                                <th>Remarks</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var f in todayFollowUps)
                            {
                                <tr>
                                    <td class="fw-600">@f.CustomerName</td>
                                    <td class="muted">@f.CustomerMobile</td>
                                    <td><span class="badge badge-followup">@f.Status</span></td>
                                    <td class="muted">@f.Remarks</td>
                                    <td>
                                        <a href="/salesman/followups" class="btn-primary-glass btn-sm">
                                            <i class="bi bi-pencil"></i> Update
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@code {
    private AttendanceRecord? todayRecord;
    private List<Customer> todayCustomers = new();
    private List<FollowUp> todayFollowUps = new();
    private int totalCustomers = 0;
    private int pendingFollowUps = 0;
    private bool isLoading = true;
    private string? staffId;
    private string currentTime = DateTime.Now.ToString("hh:mm:ss tt");

    protected override async Task OnInitializedAsync()
    {
        var userId = AuthService.GetCurrentUser()?.Id ?? "";
        var staff = await StaffService.GetStaffByUserIdAsync(userId);
        staffId = staff?.Id;

        if (staffId != null)
            await LoadData();

        isLoading = false;
    }

    private async Task LoadData()
    {
        if (staffId == null) return;
        todayRecord = await AttendanceService.GetRecordByStaffAndDateAsync(staffId, DateTime.Today);
        todayCustomers = (await CustomerService.GetCustomersByStaffAsync(staffId))
            .Where(c => c.VisitDate == DateTime.Today.ToString("yyyy-MM-dd")).ToList();
        var allCustomers = await CustomerService.GetCustomersByStaffAsync(staffId);
        totalCustomers = allCustomers.Count;
        todayFollowUps = await FollowUpService.GetTodayFollowUpsAsync(staffId);
        pendingFollowUps = await FollowUpService.GetPendingCountByStaffAsync(staffId);
        currentTime = DateTime.Now.ToString("hh:mm:ss tt");
    }

    private async Task CheckIn()
    {
        if (staffId == null) return;
        await AttendanceService.CheckInAsync(staffId);
        await LoadData();
    }

    private async Task CheckOut()
    {
        if (staffId == null) return;
        await AttendanceService.CheckOutAsync(staffId);
        await LoadData();
    }

    private string GetStatusBadge(string status) => status.Replace(" ", "").ToLower();
}
