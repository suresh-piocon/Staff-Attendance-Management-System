@page "/admin/dashboard"
@attribute [Authorize(Roles = "Admin")]
@inject ReportService ReportService
@inject SalesmanService SalesmanService

<PageTitle>Admin Dashboard — Silk Saree</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
    <div class="page-header-actions">
        <button class="btn-secondary-glass btn-sm" @onclick="LoadData">
            <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-container">
        <span class="spinner-sm"></span> Loading dashboard...
    </div>
}
else if (stats != null)
{
    <div class="kpi-grid">
        <div class="kpi-card gold">
            <div class="kpi-icon gold"><i class="bi bi-people"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@stats.TotalSalesmen</div>
                <div class="kpi-label">Total Salesmen</div>
            </div>
        </div>
        <div class="kpi-card green">
            <div class="kpi-icon green"><i class="bi bi-check-circle"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@stats.PresentToday</div>
                <div class="kpi-label">Present Today</div>
            </div>
        </div>
        <div class="kpi-card red">
            <div class="kpi-icon red"><i class="bi bi-x-circle"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@stats.AbsentToday</div>
                <div class="kpi-label">Absent Today</div>
            </div>
        </div>
        <div class="kpi-card blue">
            <div class="kpi-icon blue"><i class="bi bi-person-plus"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@stats.TodayCustomers</div>
                <div class="kpi-label">Today's Customers</div>
            </div>
        </div>
        <div class="kpi-card purple">
            <div class="kpi-icon purple"><i class="bi bi-bell"></i></div>
            <div class="kpi-body">
                <div class="kpi-value">@stats.TotalPendingFollowUps</div>
                <div class="kpi-label">Pending Follow-Ups</div>
            </div>
        </div>
    </div>

    <!-- Salesman Performance Table -->
    <div class="glass-card">
        <div class="card-header">
            <div class="card-title"><i class="bi bi-trophy"></i> Salesman Performance</div>
        </div>
        <div class="card-body" style="padding:0;">
            <div class="data-table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Salesman</th>
                            <th>Customers</th>
                            <th>Converted</th>
                            <th>Pending Follow-Ups</th>
                            <th>Conversion Rate</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in stats.SalesmanStats)
                        {
                            <tr>
                                <td class="fw-600">@s.SalesmanName</td>
                                <td>@s.TotalCustomers</td>
                                <td class="text-success">@s.ConvertedCustomers</td>
                                <td>@s.PendingFollowUps</td>
                                <td>
                                    <div class="performance-bar">
                                        <div class="perf-bar-track">
                                            <div class="perf-bar-fill" style="width:@(s.ConversionRate)%"></div>
                                        </div>
                                        <span style="font-size:12px;color:var(--gold);font-weight:600;min-width:36px;">@s.ConversionRate%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private AdminDashboardStats? stats;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        isLoading = true;
        StateHasChanged();
        stats = await ReportService.GetAdminDashboardStatsAsync();
        isLoading = false;
    }
}
