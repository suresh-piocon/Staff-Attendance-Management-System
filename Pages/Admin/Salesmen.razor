@page "/admin/salesmen"
@attribute [Authorize(Roles = "Admin")]
@inject SalesmanService SalesmanService

<PageTitle>Salesmen — Silk Saree</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-people"></i> Salesmen</h1>
    <div class="page-header-actions">
        <button class="btn-primary-glass" @onclick="() => { showModal = true; editMode = false; currentSalesman = new Salesman(); }">
            <i class="bi bi-plus-lg"></i> Add Salesman
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-container"><span class="spinner-sm"></span> Loading...</div>
}
else
{
    <div class="glass-card">
        <div class="card-body" style="padding:0;">
            <div class="data-table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Mobile</th>
                            <th>Joining Date</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var (s, i) in salesmen.Select((s, i) => (s, i + 1)))
                        {
                            <tr>
                                <td class="muted">@i</td>
                                <td class="fw-600">@s.Name</td>
                                <td class="muted">@s.Mobile</td>
                                <td class="muted">@s.JoiningDate</td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge badge-present"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-absent"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-8">
                                        <button class="btn-secondary-glass btn-sm btn-icon" title="Edit" @onclick="() => EditSalesman(s)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-secondary-glass btn-sm btn-icon" title="Toggle Active"
                                                @onclick="() => ToggleActive(s)">
                                            <i class="bi @(s.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off text-danger")"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (showModal)
{
    <div class="modal-overlay" @onclick:stopPropagation>
        <div class="modal-box">
            <div class="modal-header">
                <h3><i class="bi bi-person"></i> @(editMode ? "Edit" : "Add") Salesman</h3>
                <button class="modal-close" @onclick="() => showModal = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Full Name *</label>
                    <input class="form-control" placeholder="Enter name" @bind="currentSalesman.Name" />
                </div>
                <div class="form-group">
                    <label class="form-label">Mobile Number</label>
                    <input class="form-control" placeholder="10-digit mobile" @bind="currentSalesman.Mobile" />
                </div>
                <div class="form-group">
                    <label class="form-label">Joining Date</label>
                    <input type="date" class="form-control"
                           value="@currentSalesman.JoiningDate"
                           @onchange="@(e => currentSalesman.JoiningDate = e.Value?.ToString())" />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary-glass" @onclick="() => showModal = false">Cancel</button>
                <button class="btn-primary-glass" @onclick="SaveSalesman" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner-sm"></span> }
                    @(editMode ? "Update" : "Add")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Salesman> salesmen = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool editMode = false;
    private bool isSaving = false;
    private Salesman currentSalesman = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadSalesmen();
    }

    private async Task LoadSalesmen()
    {
        isLoading = true;
        salesmen = await SalesmanService.GetAllSalesmenAsync();
        isLoading = false;
    }

    private void EditSalesman(Salesman s)
    {
        currentSalesman = new Salesman { Id = s.Id, Name = s.Name, Mobile = s.Mobile, JoiningDate = s.JoiningDate, IsActive = s.IsActive };
        editMode = true;
        showModal = true;
    }

    private async Task SaveSalesman()
    {
        if (string.IsNullOrWhiteSpace(currentSalesman.Name)) return;
        isSaving = true;
        if (editMode)
            await SalesmanService.UpdateSalesmanAsync(currentSalesman);
        else
            await SalesmanService.AddSalesmanAsync(currentSalesman);
        isSaving = false;
        showModal = false;
        await LoadSalesmen();
    }

    private async Task ToggleActive(Salesman s)
    {
        await SalesmanService.ToggleActiveAsync(s.Id, !s.IsActive);
        await LoadSalesmen();
    }
}
