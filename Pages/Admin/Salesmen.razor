@page "/admin/salesmen"
@attribute [Authorize(Roles = "Admin")]
@inject StaffService StaffService

<PageTitle>Staff Master — Silk Saree</PageTitle>

<div class="page-header">
    <h1><i class="bi bi-people"></i> Staff Master Setup</h1>
    <div class="page-header-actions">
        <button class="btn-primary-glass" @onclick="OpenAddModal">
            <i class="bi bi-plus-lg"></i> Add Staff Member
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="loading-container"><span class="spinner-sm"></span> Loading staff data...</div>
}
else
{
    <div class="glass-card">
        <div class="card-body" style="padding:0;">
            <div class="data-table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Mobile</th>
                            <th>Designation</th>
                            <th>Fingerprint ID</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in staffList)
                        {
                            <tr>
                                <td class="text-gold fw-600">@s.StaffCode</td>
                                <td class="fw-600">@s.Name</td>
                                <td class="muted">@s.Mobile</td>
                                <td class="muted">@s.Designation</td>
                                <td class="text-info">@s.FingerprintEmpId</td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge badge-present"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-absent"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex gap-8">
                                        <button class="btn-secondary-glass btn-sm btn-icon" title="Edit" @onclick="() => EditStaff(s)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn-secondary-glass btn-sm btn-icon" title="Toggle Active"
                                                @onclick="() => ToggleActive(s)">
                                            <i class="bi @(s.IsActive ? "bi-toggle-on text-success" : "bi-toggle-off text-danger")"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@if (showModal)
{
    <div class="modal-overlay" @onclick:stopPropagation>
        <div class="modal-box">
            <div class="modal-header">
                <h3><i class="bi bi-person"></i> @(editMode ? "Edit" : "Add") Staff Member</h3>
                <button class="modal-close" @onclick="() => showModal = false">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Staff Code *</label>
                    <input class="form-control" placeholder="e.g. S001" @bind="currentStaff.StaffCode" disabled="@editMode" />
                </div>
                <div class="form-group">
                    <label class="form-label">Full Name *</label>
                    <input class="form-control" placeholder="Enter name" @bind="currentStaff.Name" />
                </div>
                <div class="form-group">
                    <label class="form-label">Mobile Number</label>
                    <input class="form-control" placeholder="10-digit mobile" @bind="currentStaff.Mobile" />
                </div>
                <div class="form-group">
                    <label class="form-label">Designation</label>
                    <input class="form-control" placeholder="e.g. Salesman A" @bind="currentStaff.Designation" />
                </div>
                <div class="form-group">
                    <label class="form-label">Fingerprint Device Employee ID</label>
                    <input class="form-control" placeholder="e.g. F001" @bind="currentStaff.FingerprintEmpId" />
                </div>
                <div class="form-group d-flex align-items-center gap-8 mt-12">
                    <input type="checkbox" id="activeCheckbox" @bind="currentStaff.IsActive" style="width: 16px; height: 16px;" />
                    <label for="activeCheckbox" class="form-label mb-0" style="cursor: pointer;">Active Status</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary-glass" @onclick="() => showModal = false">Cancel</button>
                <button class="btn-primary-glass" @onclick="SaveStaff" disabled="@isSaving">
                    @if (isSaving) { <span class="spinner-sm"></span> }
                    @(editMode ? "Update" : "Add")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Staff> staffList = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool editMode = false;
    private bool isSaving = false;
    private Staff currentStaff = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStaff();
    }

    private async Task LoadStaff()
    {
        isLoading = true;
        staffList = await StaffService.GetAllStaffAsync();
        isLoading = false;
    }

    private void OpenAddModal()
    {
        currentStaff = new Staff();
        // Generate next code S00X
        if (staffList.Any())
        {
            var codes = staffList.Select(s => s.StaffCode).ToList();
            var maxNum = codes
                .Select(c => c.StartsWith("S") && int.TryParse(c.Substring(1), out int n) ? n : 0)
                .Max();
            currentStaff.StaffCode = $"S{(maxNum + 1):D3}";
            currentStaff.FingerprintEmpId = $"F{(maxNum + 1):D3}";
        }
        else
        {
            currentStaff.StaffCode = "S001";
            currentStaff.FingerprintEmpId = "F001";
        }

        editMode = false;
        showModal = true;
    }

    private void EditStaff(Staff s)
    {
        currentStaff = new Staff
        {
            Id = s.Id,
            StaffCode = s.StaffCode,
            Name = s.Name,
            Mobile = s.Mobile,
            Designation = s.Designation,
            FingerprintEmpId = s.FingerprintEmpId,
            IsActive = s.IsActive,
            UserId = s.UserId,
            CreatedDate = s.CreatedDate
        };
        editMode = true;
        showModal = true;
    }

    private async Task SaveStaff()
    {
        if (string.IsNullOrWhiteSpace(currentStaff.Name) || string.IsNullOrWhiteSpace(currentStaff.StaffCode)) return;
        isSaving = true;
        
        try
        {
            if (editMode)
                await StaffService.UpdateStaffAsync(currentStaff);
            else
                await StaffService.AddStaffAsync(currentStaff);
            
            showModal = false;
            await LoadStaff();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Error saving staff: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ToggleActive(Staff s)
    {
        await StaffService.ToggleActiveAsync(s.Id, !s.IsActive);
        await LoadStaff();
    }
}
